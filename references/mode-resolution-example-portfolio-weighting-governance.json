  "dispatch_actions": {
    "portfolio_and_optimization_mode": {
      "if_missing": "loop back to demand_constraint_modeling or branch_plan_generation depending on the missing portfolio artifact",
      "why": "portfolio outputs depend on stable multi-objective structure"
    },
    "library_and_weighting_mode": {
      "if_missing": "loop back to branch_plan_generation",
      "why": "weighting requires stable candidate paths and criteria"
    },
    "governance_and_feedback_mode": {
      "if_missing": "loop back to evaluation_validation",
      "why": "override policy must be explicit before final commitment"
    }
  },
  "scope_alignment_status": "aligned",
  "resolution_status": "ready",
  "mode_precedence": [
    {
      "higher_mode": "portfolio_and_optimization_mode",
      "lower_mode": "library_and_weighting_mode",
      "precedence_basis": "portfolio defines the candidate-path universe and preserves the approximate-best set",
      "applies_to": [
        "candidate path inclusion",
        "non-dominated set membership"
      ],
      "note": "Weighting may rank within the set, but it should not silently collapse the portfolio's broader approximation space."
    },
    {
      "higher_mode": "governance_and_feedback_mode",
      "lower_mode": "library_and_weighting_mode",
      "precedence_basis": "human override outranks automatic ranking",
      "applies_to": [
        "final route adoption",
        "weight adoption"
      ],
      "note": "Automatic weighting remains valid as upstream decision support."
    }
  ],
  "cross_mode_handoffs": [
    {
      "from_mode": "portfolio_and_optimization_mode",
      "to_mode": "library_and_weighting_mode",
      "via_artifact": "optimization-report.json",
      "handoff_purpose": "Provide candidate paths, tradeoffs, and approximate-best set before ranking support is applied.",
      "conflict_if_missing": "Weighting may rank a space that portfolio never stabilized."
    },
    {
      "from_mode": "portfolio_and_optimization_mode",
      "to_mode": "library_and_weighting_mode",
      "via_artifact": "method-branch-map.json",
      "handoff_purpose": "Provide branch-level changed constraints and weights so weighting does not ignore branch asymmetry.",
      "conflict_if_missing": "Ranking may flatten routes that belong to materially different branch conditions."
    },
    {
      "from_mode": "library_and_weighting_mode",
      "to_mode": "governance_and_feedback_mode",
      "via_artifact": "decision-weighting.json",
      "handoff_purpose": "Provide ranked options and fallback weighting source before any human override is applied.",
      "conflict_if_missing": "Override policy loses a concrete upstream ranking target."
    }
  ],
  "authority_boundaries": [
