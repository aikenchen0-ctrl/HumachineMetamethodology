  "mode_sources": [
    {
      "mode": "portfolio_and_optimization_mode",
      "source": "explicit_user_request",
      "basis": [
        "the round requires multi-path approximate-optimal comparison",
        "research and execution planning need to be layered"
      ]
    },
    {
      "mode": "library_and_weighting_mode",
      "source": "system_inference",
      "basis": [
        "candidate paths need explicit ranking support",
        "no explicit human weights have been supplied yet"
      ]
    },
    {
      "mode": "governance_and_feedback_mode",
      "source": "explicit_user_request",
      "basis": [
        "human override authority must remain explicit",
        "automatic ranking is not the final authority once human review enters"
      ]
    }
  ],
  "activation_reasons": [
    {
      "mode": "portfolio_and_optimization_mode",
      "reasons": [
        "The round must preserve a near-optimal set instead of collapsing early to one path.",
        "Methodology branching and staged commitment are first-class requirements."
      ]
    },
    {
      "mode": "library_and_weighting_mode",
      "reasons": [
        "A ranking aid is needed to compare candidate paths inside the near-optimal set.",
        "A fallback weighting method is required because human weights are absent."
      ]
    },
    {
      "mode": "governance_and_feedback_mode",
      "reasons": [
        "The ranking result must stay overridable by humans.",
        "The round needs explicit override priority and review checkpoints before commitment."
      ]
    }
  ],
  "source_alignment_basis": [
